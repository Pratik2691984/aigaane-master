{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aigaane.local/schemas/dhatu.schema.v2.json",
  "title": "Aigaane Canonical Dhatu Record v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "version",
    "id",
    "identity",
    "grammar",
    "semantics",
    "padaProfile",
    "forms",
    "derivations",
    "upasargaVariants",
    "prakriyaRefs",
    "sources",
    "tags"
  ],
  "properties": {
    "schema": {
      "const": "aigaane.dhatu.v2"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9]{2}\\.[0-9]{4}$"
    },
    "identity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["root", "rootIast", "canonicalForm"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "rootIast": { "type": "string", "minLength": 1 },
        "canonicalForm": { "type": "string", "minLength": 1 }
      }
    },
    "grammar": {
      "type": "object",
      "additionalProperties": true,
      "required": ["gana"],
      "properties": {
        "gana": {
          "type": "object",
          "additionalProperties": true,
          "required": ["id", "slug", "name"],
          "properties": {
            "id": { "type": "string", "pattern": "^[0-9]{2}$" },
            "slug": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "semantics": {
      "type": "object"
    },
    "padaProfile": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ruleTriggers": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[1-8]\\.[1-4]\\.[0-9]+$"
          }
        }
      }
    },
    "forms": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/lakaraMatrix"
          }
        }
      }
    },
    "derivations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "base"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "base": { "type": "string", "minLength": 1 }
        }
      }
    },
    "upasargaVariants": {
      "type": "array"
    },
    "prakriyaRefs": {
      "type": "array"
    },
    "sources": {
      "type": "array",
      "minItems": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "lakaraMatrix": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
